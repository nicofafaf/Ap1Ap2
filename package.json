{
  "name": "lernenschule-nexus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:assets": "vitest run src/lib/nexusAssetManifest.test.ts",
    "prune:assets": "node scripts/prune-nexus-assets.mjs",
    "generate:ap-drills": "node scripts/generate-ap-exam-drills.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run audit:curriculum && npm run audit:cisco-modules",
    "audit:curriculum": "vite-node scripts/audit-curriculum.mjs",
    "audit:cisco-modules": "node scripts/audit-cisco-modules.mjs",
    "optimize:ranks": "node scripts/optimize-rank-assets.mjs",
    "fetch:cisco": "node scripts/fetch-ccna1-itn-html.mjs",
    "import:cisco": "node scripts/import-cisco-html.mjs --all",
    "scrape:cisco-exhibits": "node scripts/scrape-cisco-exhibit-images.mjs",
    "refresh:cisco": "node scripts/fetch-ccna1-itn-html.mjs && node scripts/import-cisco-html.mjs --all && node scripts/scrape-cisco-exhibit-images.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.23.22",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
