          "correct": false
        },
        {
          "id": "c",
          "text": {
            "en": "It is the IP address of the ISP network device located in the cloud.",
            "de": null
          },
          "correct": false
        },
        {
          "id": "d",
          "text": {
            "en": "It is the IP address of Switch1 that connects PC1 to other devices on the same LAN.",
